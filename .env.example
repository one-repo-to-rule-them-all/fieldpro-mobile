# API base URL — no trailing slash
# Local dev (Android emulator uses 10.0.2.2 to reach host machine)
EXPO_PUBLIC_API_URL=http://10.0.2.2:8000

# For physical device on same network, use your machine's LAN IP:
# EXPO_PUBLIC_API_URL=http://192.168.1.x:8000

# Production
# EXPO_PUBLIC_API_URL=https://api.fieldpro.app
